<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @owner.first_name %> <%= @owner.last_name %></h1>
  <div>
    <%= link_to "Edit", edit_owner_path(@owner), class: "btn btn-warning me-1" %>
    <%= button_to "Delete", @owner, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<p><strong>Email:</strong> <%= @owner.email %></p>
<p><strong>Phone:</strong> <%= @owner.phone %></p>
<p><strong>Address:</strong> <%= @owner.address %></p>

<h2>Pets</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
    </tr>
  </thead>
  <tbody>
    <% @owner.pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back", owners_path, class: "btn btn-secondary" %>