<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Owners</h1>
  <%= link_to "New Owner", new_owner_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Pets</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td><%= link_to "#{owner.first_name} #{owner.last_name}", owner %></td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td><%= owner.pets.count %></td>
        <td>
          <%= link_to "Edit", edit_owner_path(owner), class: "btn btn-sm btn-warning me-1" %>
          <%= button_to "Delete", owner, method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>