<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @vet.first_name %> <%= @vet.last_name %></h1>
  <div>
    <%= link_to "Edit", edit_vet_path(@vet), class: "btn btn-warning me-1" %>
    <%= button_to "Delete", @vet, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<p><strong>Email:</strong> <%= @vet.email %></p>
<p><strong>Phone:</strong> <%= @vet.phone %></p>
<p><strong>Specialization:</strong> <%= @vet.specialization %></p>

<h2>Upcoming Appointments</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr><th>Date</th><th>Pet</th><th>Reason</th><th>Status</th></tr>
  </thead>
  <tbody>
    <% @vet.appointments.upcoming.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to appointment.pet.name, appointment.pet %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Past Appointments</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr><th>Date</th><th>Pet</th><th>Reason</th><th>Status</th></tr>
  </thead>
  <tbody>
    <% @vet.appointments.past.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to appointment.pet.name, appointment.pet %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Other Vets in <%= @vet.specialization %></h2>
<ul>
  <% Vet.by_specialization(@vet.specialization).where.not(id: @vet.id).each do |v| %>
    <li><%= link_to "#{v.first_name} #{v.last_name}", v %></li>
  <% end %>
</ul>

<%= link_to "Back", vets_path, class: "btn btn-secondary" %>