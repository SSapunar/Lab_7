<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Appointments</h1>
  <%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary" %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to appointment.pet.name, appointment.pet %></td>
        <td><%= "#{appointment.vet.first_name} #{appointment.vet.last_name}" %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
        <td>
          <%= link_to "View", appointment, class: "btn btn-sm btn-secondary me-1" %>
          <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-warning me-1" %>
          <%= button_to "Delete", appointment, method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>