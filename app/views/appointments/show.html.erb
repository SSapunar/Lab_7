<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Appointment Details</h1>

  <div class="d-flex">
    <%= link_to "Edit", edit_appointment_path(@appointment), class: "btn btn-warning me-2" %>

    <%= button_to "Delete",
      @appointment,
      method: :delete,
      class: "btn btn-danger",
      data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<p><strong>Date:</strong> <%= @appointment.date.strftime("%B %d, %Y") %></p>
<p><strong>Reason:</strong> <%= @appointment.reason %></p>
<p><strong>Status:</strong> <%= @appointment.status %></p>
<p><strong>Pet:</strong> <%= link_to @appointment.pet.name, @appointment.pet %></p>
<p><strong>Vet:</strong> <%= link_to "#{@appointment.vet.first_name} #{@appointment.vet.last_name}", @appointment.vet %></p>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h2>Treatments</h2>

  <%= link_to "New Treatment",
    new_appointment_treatment_path(@appointment),
    class: "btn btn-primary btn-sm" %>
</div>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Name</th>
      <th>Medication</th>
      <th>Dosage</th>
      <th>Administered</th>
      <th>Clinical Notes</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @appointment.treatments.each do |treatment| %>
      <tr>
        <td><%= treatment.name %></td>

        <td><%= treatment.medication %></td>

        <td><%= treatment.dosage %></td>

        <td>
          <%= treatment.administered_at&.strftime("%B %d, %Y %H:%M") %>
        </td>

        <td>
          <%= treatment.clinical_notes %>
        </td>

        <td class="text-nowrap">
          <%= link_to "Edit",
            edit_appointment_treatment_path(@appointment, treatment),
            class: "btn btn-sm btn-warning me-1" %>

          <%= button_to "Delete",
            appointment_treatment_path(@appointment, treatment),
            method: :delete,
            class: "btn btn-sm btn-danger",
            data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back", appointments_path, class: "btn btn-secondary" %>