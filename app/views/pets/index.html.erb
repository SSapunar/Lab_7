<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Pets</h1>
  <%= link_to "New Pet", new_pet_path, class: "btn btn-primary" %>
</div>

<div class="mb-3">
  <%= link_to "All", pets_path, class: "btn btn-sm btn-primary me-1" %>
  <% @species_list.each do |s| %>
    <%= link_to s.capitalize, pets_path(species: s), class: "btn btn-sm btn-outline-secondary me-1" %>
  <% end %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner</th>
      <th>Date of Birth</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", pet.owner %></td>
        <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td>
        <td>
          <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-warning me-1" %>
          <%= button_to "Delete", pet, method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>