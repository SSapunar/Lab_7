<h1 class="mb-4">Pets</h1>

<%# Filtro por especie %>
<div class="mb-3">
  <%= link_to "All", pets_path, class: "btn btn-sm btn-primary me-1" %>
  <% @species_list.each do |s| %>
    <%= link_to s.capitalize, pets_path(species: s), class: "btn btn-sm btn-outline-secondary me-1" %>
  <% end %>
</div>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner</th>
      <th>Date of Birth</th>
    </tr>
  </thead>

  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= link_to "#{pet.owner.first_name} #{pet.owner.last_name}", pet.owner %></td>
        <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Back", owners_path, class: "btn btn-secondary" %>