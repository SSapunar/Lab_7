<div class="d-flex justify-content-between align-items-center mb-3">
  <h1><%= @pet.name %></h1>
  <div>
    <%= link_to "Edit", edit_pet_path(@pet), class: "btn btn-warning me-1" %>
    <%= button_to "Delete", @pet, method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>

<p><strong>Species:</strong> <%= @pet.species %></p>
<p><strong>Breed:</strong> <%= @pet.breed %></p>
<p><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") %></p>
<p><strong>Weight:</strong> <%= @pet.weight %></p>
<p><strong>Owner:</strong> <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", @pet.owner %></p>

<h2>Upcoming Appointments</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @pet.appointments.upcoming.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", appointment.vet %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Past Appointments</h2>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @pet.appointments.past.each do |appointment| %>
      <tr>
        <td><%= appointment.date.strftime("%B %d, %Y") %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", appointment.vet %></td>
        <td><%= appointment.reason %></td>
        <td><%= appointment.status %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<h2 class="mt-4">Treatments</h2>

<div class="mb-3">
  <% if @pet.appointments.any? %>
    <%= link_to "Add Treatment",
          new_appointment_treatment_path(@pet.appointments.first),
          class: "btn btn-primary" %>
  <% else %>
    <p class="text-muted">You need an appointment to add a treatment.</p>
  <% end %>
</div>

<% treatments = @pet.appointments.includes(:treatments).flat_map(&:treatments) %>

<% if treatments.any? %>
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Name</th>
        <th>Medication</th>
        <th>Dosage</th>
        <th>Date</th>
        <th>Appointment</th>
      </tr>
    </thead>

    <tbody>
      <% treatments.each do |treatment| %>
        <tr>
          <td><%= treatment.name %></td>
          <td><%= treatment.medication %></td>
          <td><%= treatment.dosage %></td>
          <td><%= treatment.administered_at&.strftime("%B %d, %Y") %></td>
          <td>
            <%= link_to "View",
                  appointment_path(treatment.appointment) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No treatments for this pet.</p>
<% end %>

<%= link_to "Back", pets_path, class: "btn btn-secondary" %>